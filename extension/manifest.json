{
  "manifest_version": 3,
  "name": "VEO3 Web Bridge",
  "version": "1.0",
  "description": "Kết nối tài khoản Google Ultra của bạn với VEO3 Web để tạo video (gửi cookie + giải captcha).",
  "permissions": ["cookies", "tabs", "scripting", "alarms", "storage"],
  "host_permissions": [
    "https://labs.google/*",
    "https://*.google.com/*",
    "https://www.gstatic.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "VEO3 Web Bridge" }
}
