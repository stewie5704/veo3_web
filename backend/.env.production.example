# Copy → .env trên VPS, điền giá trị thật. ĐỪNG commit file .env.
# Sinh SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(64))"

# --- Database: Postgres cho production (tạo DB + user trước) ---
DATABASE_URL=postgresql+asyncpg://veo3:MAT_KHAU@localhost:5432/veo3web

# --- Bảo mật ---
SECRET_KEY=DAN_KEY_NGAU_NHIEN_64_KY_TU_VAO_DAY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Redis: BẮT BUỘC khi chạy nhiều worker (captcha bus chạy chéo process) ---
REDIS_URL=redis://localhost:6379/0

# --- Lưu trữ ---
UPLOAD_DIR=/opt/veo3-web/uploads/videos
MAX_VIDEO_SIZE_MB=200

# --- CORS: app cùng origin nên thường không cần; thêm nếu có domain gọi chéo ---
FRONTEND_URL=https://app.aiautocut.com
CORS_ORIGINS=https://app.aiautocut.com,https://aiautocut.com

# --- Admin (seed.py tạo tài khoản admin lần đầu) ---
ADMIN_EMAIL=admin@aiautocut.com
ADMIN_PASSWORD=DOI_MAT_KHAU_MANH
