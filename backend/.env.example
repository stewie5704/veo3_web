DATABASE_URL=sqlite+aiosqlite:///./veo3web.db
# Production: postgresql+asyncpg://user:pass@localhost:5432/veo3web

# Sinh khóa mạnh: python -c "import secrets; print(secrets.token_urlsafe(64))"
# (Đổi SECRET_KEY = đăng xuất hết user + secret đã mã hóa phải lưu lại = user reconnect)
SECRET_KEY=change-me-run-the-command-above
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

REDIS_URL=redis://localhost:6379/0

UPLOAD_DIR=../uploads/videos
MAX_VIDEO_SIZE_MB=200

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-me
